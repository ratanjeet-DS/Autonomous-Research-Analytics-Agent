# Copy to .env and adjust.

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=ollama/llama3.1
LLM_TEMPERATURE=0.2

# Embeddings (runs locally via sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector DB
CHROMA_DIR=./data/chroma
COLLECTION_NAME=trading_intel
RETRIEVAL_K=6

# Optional: self-hosted Firecrawl instance (leave empty to use built-in fetcher)
FIRECRAWL_API_URL=

# Crawl limits
MAX_THREADS_PER_QUERY=5
MAX_POSTS_PER_THREAD=15
